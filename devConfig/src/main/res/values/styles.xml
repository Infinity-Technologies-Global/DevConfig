<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="DevConfigTextRegular">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="DevConfigTextBold" parent="DevConfigTextRegular">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="text_regular_12" parent="DevConfigTextRegular">
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <style name="text_regular_10" parent="DevConfigTextRegular">
        <item name="android:textSize">@dimen/_10ssp</item>
    </style>

    <style name="text_bold_16" parent="DevConfigTextBold">
        <item name="android:textSize">@dimen/_16ssp</item>
    </style>

    <style name="text_bold_14" parent="DevConfigTextBold">
        <item name="android:textSize">@dimen/_14ssp</item>
    </style>

    <style name="text_bold_12" parent="DevConfigTextBold">
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <style name="text_bold_10" parent="DevConfigTextBold">
        <item name="android:textSize">@dimen/_10ssp</item>
    </style>
</resources>
